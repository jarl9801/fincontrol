rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────
    // User registry: stores role + appId per user
    // Bootstrap: run scripts/bootstrap-users.js after
    // deploying these rules for the first time.
    // ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null
        && request.auth.uid == userId;

      allow create: if request.auth != null
        && request.auth.uid == userId;

      allow update: if request.auth != null
        && (
          request.auth.uid == userId
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    // ─────────────────────────────────────────────
    // Tenant-scoped FinControl data
    // appId acts as tenant key for multi-app isolation
    // ─────────────────────────────────────────────
    match /artifacts/{appId}/public/data/{collection}/{document=**} {
      // Helper: fetch current user's role from Firestore
      function userRole() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      }

      function isOwnTenant() {
        return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.appId == appId;
      }

      // Read: any authenticated user belonging to this tenant
      allow read: if request.auth != null && isOwnTenant();

      // Write: admins and managers of this tenant
      function isManagerOrAbove() {
        return request.auth != null && (userRole() == 'admin' || userRole() == 'manager');
      }
      allow write: if request.auth != null && isManagerOrAbove() && isOwnTenant();
    }
  }
}
